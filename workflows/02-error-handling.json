      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 },
          "conditions": [
            { "id": "if-sev-001", "leftValue": "={{ $json.Severity }}", "rightValue": "HIGH", "operator": { "type": "string", "operation": "equals" } }
