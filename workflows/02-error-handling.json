    "Extract Error Details": { "main": [[{ "node": "Append to ErrorLog", "type": "main", "index": 0 }]] },
    "Append to ErrorLog": { "main": [[{ "node": "Critical? (escalate)", "type": "main", "index": 0 }]] },
