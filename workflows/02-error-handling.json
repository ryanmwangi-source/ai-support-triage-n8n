    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "e-ts", "name": "Timestamp", "value": "={{ $now.toISO() }}", "type": "string" },
            { "id": "e-wf", "name": "Workflow", "value": "={{ $json.workflow?.name || 'Unknown workflow' }}", "type": "string" },
            { "id": "e-node", "name": "FailedNode", "value": "={{ $json.execution?.lastNodeExecuted || 'Unknown node' }}", "type": "string" },
            { "id": "e-msg", "name": "ErrorMessage", "value": "={{ $json.execution?.error?.message || $json.error?.message || 'No message' }}", "type": "string" },
            { "id": "e-url", "name": "ExecutionUrl", "value": "={{ $json.execution?.url || '' }}", "type": "string" },
            { "id": "e-sev", "name": "Severity", "value": "={{ (($json.execution?.error?.message || '') + '').toLowerCase().match(/auth|credential|quota|rate limit|forbidden|401|403|429/) ? 'HIGH' : 'STANDARD' }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [240, 448],
      "id": "8f01b704-a175-469f-a842-991e5c64c8f1",
